<Window x:Class="PL.Courier.DeliveriesHistoryList"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:PL.Courier"
        mc:Ignorable="d"
        Title="MediRoute - Delivery History" Height="750" Width="1200"
        WindowStartupLocation="CenterScreen"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Background="#FFF5F0FF" 
        Loaded="Window_Loaded"
        Closed="Window_Closed">

    <Window.Resources>
        <Color x:Key="MainPurpleColor">#A855F7</Color>
        <Color x:Key="DeepPurpleColor">#7E22CE</Color>
        <SolidColorBrush x:Key="MainPurpleBrush" Color="{StaticResource MainPurpleColor}"/>
        <SolidColorBrush x:Key="DeepPurpleBrush" Color="{StaticResource DeepPurpleColor}"/>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Width" Value="220"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D1C4E9"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border CornerRadius="12" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Margin="10,0,0,0" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"/>
                                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0" Stroke="#A855F7" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    <ToggleButton Grid.ColumnSpan="2" Background="Transparent" BorderThickness="0" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="White" BorderBrush="#D1C4E9" BorderThickness="1" CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer Margin="4" SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DropShadowEffect x:Key="ZDepth1" BlurRadius="8" ShadowDepth="2" Color="#D1C4E9" Opacity="0.4"/>

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource MainPurpleBrush}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="15,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="10,6"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Effect" Value="{StaticResource ZDepth1}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#E9D5FF" 
                                BorderThickness="1">
                            <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FAF5FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource MainPurpleBrush}"/>
                    <Setter Property="FontWeight" Value="SemiBold"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Closed Orders History" FontSize="36" FontWeight="Black" 
                   Foreground="{StaticResource MainPurpleBrush}" Margin="10,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="15" Margin="10,0,10,25" Padding="15" Effect="{StaticResource ZDepth1}">
            <StackPanel Orientation="Horizontal">
               
                <TextBlock Text="Filter By:" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold" Foreground="{StaticResource MainPurpleBrush}"/>
                <ComboBox Width="150" Height="32" VerticalContentAlignment="Center" Margin="0,0,20,0"  
                          ItemsSource="{Binding Source={StaticResource OrderTypeCollectionKey}}" 
                          SelectedValue="{Binding SelectedFilter, Mode=TwoWay}" SelectionChanged="ComboBox_SelectionChanged">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ConvertEnumToWordsKey}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="Sort By:" VerticalAlignment="Center" Margin="10,0" FontWeight="Bold" Foreground="{StaticResource MainPurpleBrush}"/>
                <ComboBox Width="150" Height="32" VerticalContentAlignment="Center" 
                          ItemsSource="{Binding Source={StaticResource ClosedDeliveryPropertyCollectionKey}}" 
                          SelectedValue="{Binding DeliverySort, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ConvertEnumToWordsKey}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Border>

        <DataGrid Grid.Row="2" 
                  ItemsSource="{Binding ClosedDeliveries}" 
                  AutoGenerateColumns="False" 
                  IsReadOnly="True" 
                  CanUserAddRows="False"
                  HeadersVisibility="Column" 
                  Background="Transparent" 
                  BorderThickness="0"
                  GridLinesVisibility="None"
                  ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}"
                  SelectedItem="{Binding SelectedDelivery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Delivery ID" Binding="{Binding DeliveryId}" Width="100"/>
                <DataGridTextColumn Header="Order ID" Binding="{Binding OrderId}" Width="90"/>
                <DataGridTextColumn Header="Order Type" Binding="{Binding OrderType}" Width="110"/>
                <DataGridTextColumn Header="Status" Binding="{Binding OrderStatus}" Width="110"/>
                <DataGridTextColumn Header="Vehicle" Binding="{Binding VehicleType}" Width="100"/>
                <DataGridTextColumn Header="Address" Binding="{Binding Address}" Width="*"/>
                <DataGridTextColumn Header="Distance (km)" Binding="{Binding ActualDistance, StringFormat={}{0:F2}}" Width="110"/>

                <DataGridTemplateColumn Width="100" Header="Details">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="Details" Background="Transparent" Foreground="{StaticResource MainPurpleBrush}" 
                                    BorderThickness="0" FontWeight="Bold" Cursor="Hand" 
                                    VerticalAlignment="Center" HorizontalAlignment="Center" 
                                    Click="ViewDetails_Click"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" FontSize="24" FontWeight="Bold" 
           HorizontalAlignment="Right" Margin="0,10,10,0" 
           Foreground="{StaticResource MainPurpleBrush}" Opacity="0.7">
    <InlineUIContainer>
        <fa:ImageAwesome Icon="Motorcycle" 
                         Height="20" 
                         Margin="0,0,8,0" 
                         VerticalAlignment="Center" 
                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=TextBlock}, Path=Foreground}"/>
    </InlineUIContainer>
    <Run Text="MediRoute"/>
        </TextBlock>
    </Grid>
</Window>