<Window x:Class="PL.Order.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:local="clr-namespace:PL.Order"
        mc:Ignorable="d"
        Title="Order Details" Height="700" Width="650"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        Background="#FFF8F0FF">
    <Window.Resources>
        <SolidColorBrush x:Key="MediPurple" Color="#A855F7"/>
        <SolidColorBrush x:Key="BorderLightPurple" Color="#D1C4E9"/>
        <SolidColorBrush x:Key="DisabledGray" Color="#F5F5F5"/>

        <Style TargetType="Label">
            <Setter Property="Foreground" Value="{StaticResource MediPurple}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="20,0,10,0"/>
        </Style>

        <Style x:Key="InputControlBase" TargetType="Control">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Width" Value="300"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Margin" Value="5,8"/>
        </Style>

        <Style x:Key="ValidatedTextBoxStyle" TargetType="TextBox" BasedOn="{StaticResource InputControlBase}">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="MainBorder" CornerRadius="12" Background="White" 
                                BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="2,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="TextBox" BasedOn="{StaticResource ValidatedTextBoxStyle}">
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightPurple}"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Foreground" Value="Gray"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ComboBox" BasedOn="{StaticResource InputControlBase}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border CornerRadius="12" Background="White" 
                                    BorderBrush="{StaticResource BorderLightPurple}" BorderThickness="1.5">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="30"/>
                                    </Grid.ColumnDefinitions>

                                    <ContentPresenter Content="{TemplateBinding SelectionBoxItem}" 
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" 
                                                      Margin="12,0,0,0" VerticalAlignment="Center"/>

                                    <Path Grid.Column="1" Data="M 0 0 L 4 4 L 8 0" Stroke="{StaticResource MediPurple}" 
                                          StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>

                                    <ToggleButton Grid.ColumnSpan="2" Background="Transparent" BorderThickness="0" 
                                                  IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="Transparent"/>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>
                                </Grid>
                            </Border>
                            <Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True">
                                <Border Background="White" BorderBrush="{StaticResource BorderLightPurple}" BorderThickness="1" CornerRadius="8" MinWidth="{TemplateBinding ActualWidth}">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="FooterButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Width" Value="170"/>
            <Setter Property="Margin" Value="10"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLightPurple}"/>
            <Setter Property="Foreground" Value="{StaticResource MediPurple}"/>
            <Setter Property="BorderThickness" Value="2"/>

            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="21" 
                        Background="{TemplateBinding Background}" 
                        BorderBrush="{TemplateBinding BorderBrush}" 
                        BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#E0E0E0"/>
                    <Setter Property="BorderBrush" Value="#BDBDBD"/>
                    <Setter Property="Foreground" Value="#888888"/>
                </Trigger>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F3E5F5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Padding="25">
        <DockPanel>
            <TextBlock DockPanel.Dock="Top" Text="Order Management" FontSize="32" 
                       FontWeight="Black" Foreground="{StaticResource MediPurple}" 
                       HorizontalAlignment="Center" Margin="0,0,0,25"/>

            <StackPanel DockPanel.Dock="Bottom">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Content="{Binding ButtonText}" 
        Style="{StaticResource FooterButtonStyle}" 
        Click="btnAddUpdate_Click">
                        <Button.IsEnabled>
                            <MultiBinding Converter="{StaticResource OrderClosedToIsEnabledUpdateConvertorKey}">
                                <Binding Path="ButtonText"/>
                                <Binding Path="CurrentOrder.OrderStatus"/>
                            </MultiBinding>
                        </Button.IsEnabled>
                    </Button>
                    <Button Style="{StaticResource FooterButtonStyle}" Click="btnOpenDeliveries_Click">
                        <StackPanel Orientation="Horizontal">
                            <fa:ImageAwesome Icon="Truck" 
                                         Foreground="{StaticResource MediPurple}" 
                                         Height="14" 
                                         Margin="0,0,8,0" />
                            <TextBlock Text="View Deliveries" 
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <TextBlock FontSize="24" FontWeight="Bold" HorizontalAlignment="Right" Margin="0,15,10,0" 
                           Foreground="{StaticResource MediPurple}" Opacity="0.7">
                    <InlineUIContainer>
                        <fa:ImageAwesome Icon="Motorcycle" Height="20" Margin="0,0,8,0" VerticalAlignment="Center" 
                                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=TextBlock}, Path=Foreground}"/>
                    </InlineUIContainer>
                    <Run Text="MediRoute"/>
                </TextBlock>
            </StackPanel>

            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="Order ID:"/>
                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding CurrentOrder.Id}" IsReadOnly="True"/>

                    <Label Grid.Row="1" Content="Order Type:"/>
                    <ComboBox Grid.Row="1" Grid.Column="1" ItemsSource="{Binding Source={StaticResource OrderTypeCollectionKey}}" SelectedItem="{Binding CurrentOrder.OrderType}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource ConvertEnumToWordsKey}}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <Label Grid.Row="2" Content="Direction:"/>
                    <ComboBox Grid.Row="2" Grid.Column="1" ItemsSource="{Binding Source={StaticResource InOrOutCollectionKey}}" SelectedItem="{Binding CurrentOrder.InOrOut}" />

                    <Label Grid.Row="3" Content="Target Address:"/>
                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding CurrentOrder.Address}"/>

                    <Label Grid.Row="4" Content="Details:"/>
                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding CurrentOrder.Description}" Height="80" AcceptsReturn="True" TextWrapping="Wrap" VerticalContentAlignment="Top" Padding="10,8"/>

                    <Label Grid.Row="5" Content="Distance:"/>
                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding CurrentOrder.AirDistance}" IsReadOnly="True" />

                    <Label Grid.Row="6" Content="Client Name:"/>
                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding CurrentOrder.ClientName}"/>

                    <Label Grid.Row="7" Content="Contact Phone:"/>
                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding CurrentOrder.ClientPhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <TextBox.Style>
                            <Style TargetType="TextBox" BasedOn="{StaticResource ValidatedTextBoxStyle}">
                                <Setter Property="BorderBrush" Value="{StaticResource BorderLightPurple}"/>
                                <Setter Property="BorderThickness" Value="1.5"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding CurrentOrder.ClientPhoneNumber, Converter={StaticResource PhoneToErrorConverterKey}}" Value="True"/>
                                            <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsFocused}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="BorderBrush" Value="Red"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Label Grid.Row="8" Content="Volume:"/>
                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding CurrentOrder.Volume}"/>

                    <Label Grid.Row="9" Content="Fragile:"/>
                    <CheckBox Grid.Row="9" Grid.Column="1" IsChecked="{Binding CurrentOrder.Fragile}" VerticalAlignment="Center" Margin="10,0"/>

                    <Label Grid.Row="10" Content="Created On:"/>
                    <DatePicker Grid.Row="10" Grid.Column="1" SelectedDate="{Binding CurrentOrder.OrderOpenedTime}" IsEnabled="False" Width="300" HorizontalAlignment="Left" Margin="5,8"/>

                    <Label Grid.Row="11" Content="Expected By:"/>
                    <DatePicker Grid.Row="11" Grid.Column="1" SelectedDate="{Binding CurrentOrder.ExpectedDeliveryTime}" IsEnabled="False" Width="300" HorizontalAlignment="Left" Margin="5,8"/>

                    <Label Grid.Row="12" Content="Status:"/>
                    <TextBox Grid.Row="12" Grid.Column="1"  Text="{Binding CurrentOrder.OrderStatus, Converter={StaticResource ConvertEnumToWordsKey}}" IsReadOnly="True"/>

                    <Label Grid.Row="13" Content="Schedule Phase:"/>
                    <TextBox Grid.Row="13" Grid.Column="1" Text="{Binding CurrentOrder.ScheduleStatus, Converter={StaticResource ConvertEnumToWordsKey}}" IsReadOnly="True"/>

                    <Label Grid.Row="14" Content="Remaining Time:"/>
                    <TextBox Grid.Row="14" Grid.Column="1" Text="{Binding CurrentOrder.RemainingTime, StringFormat='{}{0:hh\\:mm}'}" 
                             IsReadOnly="True" ToolTip="Read-only time duration"/>
                </Grid>
            </ScrollViewer>
        </DockPanel>
    </Border>
</Window>