<Window x:Class="PL.Delivery.DeliveryListWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:fa="http://schemas.fontawesome.io/icons/"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PL.Delivery"
        mc:Ignorable="d"
        Title="Delivery Details List" Height="850" Width="950"
        DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded"
        Closed="Window_Closed"
        Background="#F5F3FF">
    <Window.Resources>
        <SolidColorBrush x:Key="MainPurpleBrush" Color="#A855F7"/>
        <SolidColorBrush x:Key="DeepPurpleBrush" Color="#6D28D9"/>
        <SolidColorBrush x:Key="LightPurpleBrush" Color="#E9D5FF"/>

        <DropShadowEffect x:Key="ZDepth1" BlurRadius="8" ShadowDepth="2" Color="#A855F7" Opacity="0.2"/>

        <Style x:Key="ColumnHeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#6D28D9"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,0,0,10"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Margin" Value="0,6"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="Effect" Value="{StaticResource ZDepth1}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridRow">
                        <Border CornerRadius="15" 
                                Background="{TemplateBinding Background}" 
                                BorderBrush="#F3E8FF" 
                                BorderThickness="1" 
                                Margin="10,2">
                            <DataGridCellsPresenter ItemsPanel="{TemplateBinding ItemsPanel}" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F5F3FF"/>
                    <Setter Property="BorderBrush" Value="#A855F7"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="Transparent" Padding="10,0">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IdTextBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border CornerRadius="12" Background="White" BorderBrush="#E9D5FF" BorderThickness="2">
                            <ScrollViewer x:Name="PART_ContentHost" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Text="Deliveries History" 
                       FontSize="48" FontWeight="Black" 
                       Foreground="#A855F7" Margin="10,0,0,10"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="15,0,0,25">
                <TextBlock Text="Order ID:" FontSize="18" Foreground="#6D28D9" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox Style="{StaticResource IdTextBoxStyle}" Text="{Binding CurrentOrder.Id}" 
                         Width="120" IsReadOnly="True" FontWeight="Bold" Foreground="#4B0082" TextAlignment="Center"/>
            </StackPanel>

            <DataGrid Grid.Row="2" 
                      ItemsSource="{Binding Deliveries}" 
                      AutoGenerateColumns="False" 
                      IsReadOnly="True" 
                      CanUserAddRows="False"
                      HeadersVisibility="Column" 
                      Background="Transparent" 
                      BorderThickness="0"
                      GridLinesVisibility="None"
                      ColumnHeaderStyle="{StaticResource ColumnHeaderStyle}">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding DeliveryId}" Width="80"/>
                    <DataGridTextColumn Header="Courier" Binding="{Binding CourierName}" Width="*"/>
                    <DataGridTextColumn Header="Type" Binding="{Binding OrderType}" Width="120"/>
                    <DataGridTextColumn Header="In/Out" Binding="{Binding InOrOut}" Width="100"/>
                    <DataGridTextColumn Header="Start" Binding="{Binding DeliveryStartTime, StringFormat=\{0:dd/MM HH:mm\}}" Width="140"/>
                    <DataGridTextColumn Header="End" Binding="{Binding DeliveryEndTime, StringFormat=\{0:dd/MM HH:mm\}}" Width="140"/>

                    <DataGridTemplateColumn Header="Status" Width="130">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border Background="#F3E8FF" CornerRadius="10" Padding="8,4">
                                    <TextBlock Text="{Binding OrderStatus}" 
                                               FontWeight="Bold" 
                                               Foreground="#6D28D9" 
                                               HorizontalAlignment="Center"/>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
            <TextBlock Grid.Row="3" FontSize="26" FontWeight="Black" HorizontalAlignment="Right" Margin="0,20,10,0">
                <TextBlock.Foreground>
                    <LinearGradientBrush EndPoint="1,0.5" StartPoint="0,0.5">
                        <GradientStop Color="#6D28D9" Offset="0"/>
                        <GradientStop Color="#A855F7" Offset="1"/>
                    </LinearGradientBrush>
                </TextBlock.Foreground>
    <InlineUIContainer>
        <fa:ImageAwesome Icon="Motorcycle" 
                         Height="22" 
                         Margin="0,0,10,0" 
                         VerticalAlignment="Center" 
                         Foreground="{Binding RelativeSource={RelativeSource AncestorType=TextBlock}, Path=Foreground}"/>
    </InlineUIContainer>
    <Run Text="MediRoute"/>
            </TextBlock>
        </Grid>
    </Grid>
</Window>